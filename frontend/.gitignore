# ============================================================
# RAG-OUTLOOK — Root .gitignore
# Covers: Python · Node/Next.js · Docker · Terraform · Kubernetes · OS/IDE
# ============================================================

# ------------------------------------------------------------
# Environment & Secrets  (NEVER commit these)
# ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.test.example
*.pem
*.key
*.crt
*.p12
ssl/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
develop-eggs/
downloads/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover
cover/

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# Jupyter
.ipynb_checkpoints
profile_default/
ipython_config.py

# Celery
celerybeat-schedule
celerybeat.pid

# Package managers
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
*.manifest
*.spec

# Alembic (dev only — versions tracked in backend/.gitignore)
# backend/alembic/versions/*

# ------------------------------------------------------------
# Node / Next.js / Frontend
# ------------------------------------------------------------
node_modules/
.next/
.nuxt/
out/
.turbo/
dist/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Package manager locks (keep package-lock.json / yarn.lock)
# Uncomment to ignore:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Docker  (data volumes, generated compose overrides)
# ------------------------------------------------------------
infrastructure/docker/data/
infrastructure/postgres/data/
**/data/db/
docker-compose.override.yml

# ------------------------------------------------------------
# Terraform
# ------------------------------------------------------------
infrastructure/terraform/.terraform/
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.*
infrastructure/terraform/*.tfvars
infrastructure/terraform/!*.tfvars.example
infrastructure/terraform/crash.log
infrastructure/terraform/crash.*.log
infrastructure/terraform/override.tf
infrastructure/terraform/override.tf.json
infrastructure/terraform/*_override.tf
infrastructure/terraform/*_override.tf.json

# ------------------------------------------------------------
# Kubernetes / Helm
# ------------------------------------------------------------
infrastructure/kubernetes/secrets/
infrastructure/kubernetes/**/*-secret.yaml
infrastructure/kubernetes/**/*-secrets.yaml
*.kubeconfig

# ------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# OS artifacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.zip
*.tar.gz
*.rar
.history/
.cache/
coverage/
.temp/
tmp/
